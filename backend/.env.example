#  ===================================================================
# ENVIRONMENT CONFIGURATION
# Copy this file to `.env` and fill in your actual values
# ===================================================================

# ------ Groq Cloud API (Generation Layer) ------
GROQ_API_KEY=gsk_your_groq_api_key_here

# ------ WordPress MySQL Database ------
# Format: mysql+pymysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
# Example for XAMPP:   mysql+pymysql://root:@localhost:3306/wordpress
# Example for Docker:  mysql+pymysql://wordpress:wordpress@localhost:3306/wordpress
WP_DB_URI=mysql+pymysql://root:@localhost:3306/wordpress
WP_TABLE_PREFIX=wp_

# ------ Infrastructure (Docker Services) ------
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=wp_healthcare_content
REDIS_URL=redis://localhost:6379/0

# ------ Groq Model ------
GROQ_MODEL=llama-3.3-70b-versatile

# ------ RAG Tuning ------
CHUNK_SIZE=500
CHUNK_OVERLAP=50
EMBEDDING_MODEL_NAME=BAAI/bge-m3
RETRIEVAL_TOP_K=10
EMBEDDING_BATCH_SIZE=32
